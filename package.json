{
  "name": "dbeditor",
  "private": true,
  "scripts": {
    "dev": "concurrently -n backend,frontend -c cyan,magenta \"cd backend && go run .\" \"pnpm --filter frontend dev\"",
    "build:frontend": "pnpm --filter frontend build",
    "typecheck": "pnpm --filter frontend typecheck",
    "backend": "cd backend && go run .",
    "frontend": "pnpm --filter frontend dev"
  },
  "devDependencies": {
    "concurrently": "^8.2.2"
  }
}
